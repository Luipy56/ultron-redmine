# Variable names below are the defaults. To use different names, set optional
# `environment_bindings` in `config.yaml` (see `config.example.yaml`).

# =============================================================================
# Discord — bot identity and gateway
# =============================================================================

# DISCORD_TOKEN — Secret token the bot uses to connect to Discord (required).
# Example: paste from Developer Portal → Application → Bot → Reset / copy token (never commit real values).
DISCORD_TOKEN=

# DISCORD_GUILD_ID — Numeric server ID: slash commands sync to this guild on startup (fast). If unset or empty, defaults to guild 788074756044750891. Use 0 or global for global sync (slower to propagate everywhere).
# Example: 788074756044750891   or   0
DISCORD_GUILD_ID=

# DISCORD_APPLICATION_ID — OAuth2 application ID (optional; useful for invite links and some tooling).
# Example: 1234567890123456789
DISCORD_APPLICATION_ID=

# DISCORD_MESSAGE_CONTENT_INTENT — Set to 1 / true / yes to request the privileged Message Content intent (must match the Developer Portal toggle). Helps if @mentions are not detected reliably.
# Example: 1
DISCORD_MESSAGE_CONTENT_INTENT=

# ULTRON_NL_COMMANDS — If truthy, forces natural-language @mention routing on (same effect as discord.nl_commands: true in config.yaml). Optional override.
# Example: 1
ULTRON_NL_COMMANDS=

# =============================================================================
# Redmine — REST API
# =============================================================================

# REDMINE_URL — Base URL of your Redmine instance, no trailing slash (required).
# Example: https://redmine.example.com
REDMINE_URL=https://redmine.example.com

# REDMINE_API_KEY — API key from Redmine → My account → API access key (required).
# Example: 0123456789abcdef0123456789abcdef
REDMINE_API_KEY=

# REDMINE_TIME_ACTIVITY_ID — Optional numeric id of the time-entry activity for **`/log_time`** when Redmine has more than one activity or no single default. List ids via Redmine REST GET `/enumerations/time_entry_activities.json` (or use the bot’s error message when unset).
# Example: 9
REDMINE_TIME_ACTIVITY_ID=

# =============================================================================
# Language model — OpenAI-compatible HTTP API (optional overall; omit keys to run without an LLM)
# =============================================================================

# LLM_BASE_URL — Chat-completions base URL including /v1 (ignored for LLM calls when config.yaml defines a non-empty llm_chain).
# Example (OpenAI): https://api.openai.com/v1
# Example (Ollama): http://127.0.0.1:11434/v1
LLM_BASE_URL=https://api.openai.com/v1

# LLM_API_KEY — API key for the provider above (dummy value ollama is common for local Ollama). Leave empty only when not using a model or when keys come from llm_chain api_key_env vars.
# Example: sk-proj-...   or   ollama
LLM_API_KEY=

# LLM_MODEL — Default model id when using single-provider env config (not llm_chain).
# Example: gpt-4o-mini
LLM_MODEL=gpt-4o-mini

# OLLAMA_API_BASE — Optional shorthand: if set and LLM_BASE_URL is empty, Ultron uses {OLLAMA_API_BASE}/v1 and may default LLM_API_KEY to ollama.
# Example: http://127.0.0.1:11434
OLLAMA_API_BASE=

# OLLAMA_MODEL — Used when LLM_MODEL is empty (Ollama-friendly).
# Example: llama3.2
OLLAMA_MODEL=

# LLM_TIMEOUT_SECONDS — HTTP read timeout for LLM requests in seconds.
# Example: 900
LLM_TIMEOUT_SECONDS=

# LLM_MAX_RETRIES — OpenAI SDK retries per request (0 is typical for local Ollama to avoid doubling wait on failures).
# Example: 2
LLM_MAX_RETRIES=

# LLM_DISABLED — Set to 1 / true / yes to force no LLM (must not define a non-empty llm_chain in config.yaml).
# Example: 1
LLM_DISABLED=

# ULTRON_NO_LLM — Same idea as LLM_DISABLED (alternate name).
# Example: 1
ULTRON_NO_LLM=

# =============================================================================
# Paths and runtime
# =============================================================================

# CONFIG_PATH — Path to config.yaml relative to the process working directory unless absolute.
# Example: config.yaml
CONFIG_PATH=config.yaml

# ULTRON_STATE_DIR — Directory for whitelist, admins, pending /token data (should not be committed).
# Example: data
ULTRON_STATE_DIR=data

# LOG_LEVEL — Logging level for the bot process (DEBUG, INFO, WARNING, ERROR).
# Example: INFO
LOG_LEVEL=INFO

# =============================================================================
# Access control and UX
# =============================================================================

# DISCORD_ADMIN_IDS — Comma- or space-separated Discord user IDs that may use /approve, /remove, /show_config. Merged with admins.json in ULTRON_STATE_DIR.
# Example: 111111111111111111, 222222222222222222
DISCORD_ADMIN_IDS=

# BOT_OWNER_CONTACT — Optional line appended to DMs when a user is not whitelisted (e.g. how to reach the owner).
# Example: ops@example.com or @admin on Slack
BOT_OWNER_CONTACT=
