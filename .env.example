# Required: Discord bot token (Developer Portal → Bot → Token)
DISCORD_TOKEN=

# Optional: sync slash commands to one guild (faster than global during dev)
DISCORD_GUILD_ID=

# Optional: application ID (invite links / debugging)
DISCORD_APPLICATION_ID=

# Redmine REST API (no trailing slash on URL)
REDMINE_URL=https://redmine.example.com
REDMINE_API_KEY=

# OpenAI-compatible API (Ollama: http://127.0.0.1:11434/v1 with api_key=ollama)
# If config.yaml defines a non-empty llm_chain, LLM_API_KEY / LLM_BASE_URL / LLM_MODEL are unused for LLM calls.
# Example (matches default repo config.yaml order: Ollama → OpenAI → OpenRouter):
# OLLAMA_API_KEY=ollama
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# HTTP read timeout for LLM requests (seconds). Default 900.
# LLM_TIMEOUT_SECONDS=900

# OpenAI SDK retries per request. Default 0 for Ollama/local, 2 for cloud.
# LLM_MAX_RETRIES=0

# Logging: DEBUG, INFO, WARNING, ERROR (default INFO). httpx/openai stay at WARNING unless you tune them in code.
# LOG_LEVEL=INFO

# Optional: shorthand for local Ollama (sets LLM base to {OLLAMA_API_BASE}/v1 and default key "ollama")
# OLLAMA_API_BASE=http://127.0.0.1:11434
# OLLAMA_MODEL=llama3.2

# Optional: path to config.yaml (default: ./config.yaml)
# CONFIG_PATH=config.yaml

# Persistent state (whitelist, pending /token requests). Default: ./data — should not be committed to git.
# ULTRON_STATE_DIR=data

# Optional: shown to users in DM when they are not whitelisted (e.g. how to reach the bot owner)
# BOT_OWNER_CONTACT=

# Comma- or space-separated Discord user IDs that are bot admins (can use /approve and /remove). Also see admins.json in ULTRON_STATE_DIR.
# DISCORD_ADMIN_IDS=123456789012345678
